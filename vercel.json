{
  "version": 2,
  "routes": [
    { "src": "/matriz", "dest": "/matriz/index.html" },
    { "src": "/matriz/", "dest": "/matriz/index.html" },
    { "src": "/api/diagnostico", "dest": "/api/diagnostico.js" },
    { "src": "/quiz", "dest": "/quiz.html" },
    { "src": "/quiz/", "dest": "/quiz.html" },
    { "src": "/arquitetura-da-voz", "dest": "/arquitetura-da-voz/index.html" },
    { "src": "/arquitetura-da-voz/", "dest": "/arquitetura-da-voz/index.html" },
    { "src": "/(.+\\.(png|jpg|jpeg|gif|svg|ico|css|js))", "dest": "/$1" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
